{
  "$schema": "./node_modules/as-test/as-test.config.schema.json",
  "input": ["./assembly/__tests__/*.spec.ts"],
  "outDir": "./.as-test/build",
  "logs": "./.as-test/logs",
  "coverageDir": "./.as-test/coverage",
  "snapshotDir": "./.as-test/snapshots",
  "config": "none",
  "coverage": {
    "enabled": true,
    "mode": "project",
    "include": ["assembly/**/*.ts"],
    "exclude": [
      "assembly/__tests__/**/*.ts",
      "assembly/__fuzz__/**/*.fuzz.ts",
      "assembly/__bench__/**/*.bench.ts"
    ]
  },
  "buildOptions": {
    "args": ["--debug"],
    "target": "wasi"
  },
  "fuzz": {
    "input": ["./assembly/__fuzz__/*.fuzz.ts"],
    "runs": 500,
    "seed": 1337,
    "target": "bindings"
  },
  "runOptions": {
    "runtime": {
      "cmd": "wasmtime <file>"
    }
  },
  "modes": {
    "naive": {
      "env": {
        "JSON_MODE": "NAIVE"
      },
      "buildOptions": {
        "args": ["--transform ./"]
      }
    },
    "swar": {
      "env": {
        "JSON_MODE": "SWAR"
      },
      "buildOptions": {
        "args": ["--transform ./"]
      }
    },
    "simd": {
      "env": {
        "JSON_MODE": "SIMD"
      },
      "buildOptions": {
        "args": ["--debug", "--enable simd", "--transform ./"]
      }
    }
  }
}
