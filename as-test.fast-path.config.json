{
  "$schema": "./node_modules/as-test/as-test.config.schema.json",
  "input": ["./assembly/__fast_tests__/*.spec.ts"],
  "outDir": "./.as-test-fast/build",
  "logs": "./.as-test-fast/logs",
  "coverageDir": "./.as-test-fast/coverage",
  "snapshotDir": "./.as-test-fast/snapshots",
  "config": "none",
  "coverage": false,
  "buildOptions": {
    "args": ["--transform ./transform", "--debug"],
    "target": "wasi"
  },
  "runOptions": {
    "runtime": {
      "cmd": "wasmtime <file>"
    },
    "reporter": "default"
  },
  "modes": {
    "swar": {
      "env": {
        "JSON_MODE": "SWAR",
        "JSON_USE_FAST_PATH": "1"
      }
    },
    "simd": {
      "env": {
        "JSON_MODE": "SIMD",
        "JSON_USE_FAST_PATH": "1"
      },
      "buildOptions": {
        "args": ["--enable simd"]
      }
    }
  }
}
