{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2020",
    "moduleResolution": "Node",
    "ignoreDeprecations": "6.0",
    "removeComments": true,
    "types": ["node"],
    "rootDir": ".",
    "outDir": "../build",
    "sourceMap": false,
    "allowJs": true
  },
  "include": [
    "./*.ts",
    "./lib/*.ts",
    "./prim/*.bench.ts",
    "./multilib/*.bench.ts",
    "./multilib/shared.ts",
    "./multilib/*.d.ts",
    "lib/bench.js"
  ]
}
